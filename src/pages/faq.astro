---
import BaseLayout from "../layouts/BaseLayout.astro";

const 常見問題s = [
  {
    question: "第一次詢問需要準備什麼？",
    answer: "不用特別準備。帶著現在的心情前來就好。如果心裡已有想聊的事情，可以提前想一想，留下目前最困擾的一句話；如果還沒有整理好，也沒有關係。我們會陪你慢慢梳理，找到真正想面對的方向。",
  },
  {
    question: "服務是線上還是實體？",
    answer: "服務方式會依照實際需求與當下安排確認。若你不確定哪一種方式適合自己，可以先私訊詢問。",
  },
  {
    question: "費用怎麼計算？",
    answer: "費用會依服務內容與進行方式說明。建議先透過 LINE 或 Instagram 聯繫，確認適合的服務後再了解費用細節。",
  },
  {
    question: "如何預約時間？",
    answer: "可以先加入 LINE 或透過 Instagram 私訊，簡單說明想聊的方向，再一起確認適合的時間。",
  },
  {
    question: "如果我還不知道怎麼說，可以預約嗎？",
    answer: "當然可以。很多人第一次來，都只是覺得最近有些迷惘、壓力很大，或想找個地方安靜聊聊。不用擔心自己是否「問得對」，從你的近況開始，說出目前最困擾的一件事，就是最好的開始。",
  },
  ,
  {
    question: "一定要有宗教信仰嗎？",
    answer: "不用。靜初苑尊重每一種信仰，也歡迎沒有任何宗教信仰的人。",
  },
];
---

<BaseLayout title="常見問題" description="靜初苑常見問題，說明第一次詢問、服務方式、費用與預約流程。">
  <section class="page">
    <div class="narrow center">
      <h1>常見問題</h1>
      <p class="lead">第一次來到靜初苑，心中或許會有一些疑問。我們將常見的問題整理在這裡，希望能陪伴你先認識我們，也讓每一次聯繫，都從安心開始。</p>
    </div>
  </section>

  <section class="常見問題-section">
    <div class="narrow">
      {常見問題s.map((item) => (
        <article class="常見問題-item">
          <h2>{item.question}</h2>
          <p>{item.answer}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .常見問題-section {
    padding-top: 0;
  }

  .常見問題-item {
    padding: 28px 0;
    border-top: 1px solid var(--color-line);
  }

  .常見問題-item:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .常見問題-item h2 {
    margin-bottom: 10px;
    font-size: 24px;
  }
</style>
