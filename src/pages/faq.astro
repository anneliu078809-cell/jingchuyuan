---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    question: "第一次詢問需要準備什麼？",
    answer: "可以先簡單描述想聊的方向，不需要準備完整資料。若還不知道怎麼說，也可以只留下目前最困擾的一句話。",
  },
  {
    question: "服務是線上還是實體？",
    answer: "服務方式會依照實際需求與當下安排確認。若你不確定哪一種方式適合自己，可以先私訊詢問。",
  },
  {
    question: "費用怎麼計算？",
    answer: "費用會依服務內容與進行方式說明。建議先透過 LINE 或 Instagram 聯繫，確認適合的服務後再了解費用細節。",
  },
  {
    question: "如何預約時間？",
    answer: "可以先加入 LINE 或透過 Instagram 私訊，簡單說明想聊的方向，再一起確認適合的時間。",
  },
  {
    question: "如果我還不知道怎麼說，可以預約嗎？",
    answer: "可以。你不需要先整理成完整的故事，只要先說出目前最困擾、最想被理解的一件事，就可以從那裡開始。",
  },
];
---

<BaseLayout title="FAQ" description="靜初苑常見問題，說明第一次詢問、服務方式、費用與預約流程。">
  <section class="page">
    <div class="narrow center">
      <p class="eyebrow">FAQ</p>
      <h1>常見問題</h1>
      <p class="lead">將重複詢問的內容整理在這裡，讓來訪者在聯絡前先有基本理解。</p>
    </div>
  </section>

  <section class="faq-section">
    <div class="narrow">
      {faqs.map((item) => (
        <article class="faq-item">
          <h2>{item.question}</h2>
          <p>{item.answer}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .faq-section {
    padding-top: 0;
  }

  .faq-item {
    padding: 28px 0;
    border-top: 1px solid var(--color-line);
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .faq-item h2 {
    margin-bottom: 10px;
    font-size: 24px;
  }
</style>
