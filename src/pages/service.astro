---
import BaseLayout from "../layouts/BaseLayout.astro";
import PictureSlot from "../components/PictureSlot.astro";

const services = [
  {
    title: "問事服務",
    meta: "$2,600 / 1 到 1.5 小時",
    description:
      "陪你整理人生不同階段的疑惑。透過一對一對話整理當前困惑，看見事件背後的狀態與下一步方向。工作、感情、家庭、人際，都能安心聊聊。",
  },
  {
    title: "牌卡占卜",
    meta: "$200 / 10 分鐘",
    description:
      "以牌卡作為提醒與映照，協助聚焦問題、釐清選擇。占卜，不是預測未來。而是透過訊息，看見此刻最需要理解的自己。",
  },
  {
    title: "手工藥香",
    meta: "$1,690 / 70g",
    description:
      "手工製作的藥香，適合用於日常靜心，空間穩定與個人儀式感整理，讓身心重新放鬆，回到穩定、平衡的狀態。",
  },
  {
    title: "調頻蠟燭",
    meta: "$1,200 / 200 到 220g",
    description:
      "結合香氛與燭光陪伴，為日常靜心、放鬆或空間建立柔和穩定的氛圍。每個人的生命課題都不同，透過客製化的調頻蠟燭一起找到最適合你的陪伴方式。",
  },
  {
    title: "家族排列",
    meta: "個案 / 團體，費用與時間請私訊確認",
    description:
      "透過排列方式看見關係與系統中的牽動，讓卡住的議題有機會被重新理解。",
  },
  {
    title: "身體經絡放鬆引導",
    meta: "$2,000 / 1 小時",
    description:
      "以身體覺察與經絡放鬆引導，陪你回到身體，釋放累積的緊繃與壓力。",
  },
];
---

<BaseLayout
  title="服務方案"
  description="靜初苑服務方案，包含服務內容、適合對象、費用與預約方式。"
  image="/images/service/service-scene.webp"
>
  <section class="page">
    <div class="container split">
      <div>
        <p class="eyebrow">SERVICE</p>
        <h1>服務方案</h1>
        <p class="lead">
          靜初苑提供問事服務、牌卡占卜、手工藥香、調頻蠟燭、家族排列與身體經絡放鬆引導，陪你從身、心，與靈魂到空間慢慢回到穩定。
        </p>
        <div class="button-row">
          <a class="button" href="/contact/">直接預約</a>
          <a class="button secondary" href="/faq/">閱讀 常見問題</a>
        </div>
      </div>
      <PictureSlot
        src="/images/service/service-scene.webp"
        alt="靜初苑服務情境"
        label="靜初苑服務"
        variant="tall"
      />
    </div>
  </section>

  <section class="band">
    <div class="container">
      <p class="eyebrow">DETAILS</p>
      <h2>服務方案</h2>
      <div class="grid service-grid">
        {
          services.map((service) => (
            <article class="card service-card">
              <h3>{service.title}</h3>
              <p class="service-price-tag">{service.meta}</p>
              <p>{service.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div>
        <p class="eyebrow">PRICE & BOOKING</p>
        <h2>付款方式與預約方式</h2>
        <ul class="list">
          <li>付款方式：費用請於約定日期前完成付款。可接受匯款/Linepay。</li>
          <li>預約方式：請Email或透過官方帳號安排時間。</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .service-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .page :global(.image-slot.tall img) {
    object-position: 35% center;
  }

  .service-card {
    display: flex;
    min-height: 220px;
    flex-direction: column;
  }

  .service-card h3 {
    margin-bottom: 12px;
    color: var(--color-gold-dark);
  }

  .service-card p:last-child {
    margin-bottom: 0;
  }

  .service-price-tag {
    display: flex;
    align-items: center;
    width: fit-content;
    margin: 0 0 18px;
    padding: 6px;
    border: 1px solid rgba(128, 85, 44, 0.34);
    background: rgba(255, 250, 244, 0.78);
    color: #654022;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.35;
  }

  .list li:last-child {
    border-bottom: 0;
  }

  @media (max-width: 900px) {
    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
