---
import BaseLayout from "../layouts/BaseLayout.astro";
import PictureSlot from "../components/PictureSlot.astro";

const services = [
  {
    title: "💕問事服務",
    price: "$2600",
    meta: "1~1.5hr",
    description: "透過一對一對話整理當前困惑，看見事件背後的狀態與下一步方向。",
  },
  {
    title: "💕牌卡占卜",
    price: "$200",
    meta: "10分鐘",
    description: "以牌卡作為提醒與映照，協助聚焦問題、釐清選擇與目前能量流向。",
  },
  {
    title: "💕手工藥香",
    price: "$1690",
    meta: "70g",
    description: "手工製作的藥香，適合用於日常靜心、空間安定與個人儀式感整理。",
  },
  {
    title: "💕調頻蠟燭",
    price: "$1200",
    meta: "200~220g",
    description: "結合香氣與燭光陪伴，為冥想、放鬆或空間轉換建立柔和穩定的氛圍。",
  },
  {
    title: "💕家族排列",
    price: "個案 / 團體",
    meta: "依場次確認",
    description: "透過排列方式看見關係與系統中的牽動，讓卡住的議題有機會被重新理解。",
  },
  {
    title: "💕身體經絡放鬆引導",
    price: "$2000",
    meta: "1hr",
    description: "以身體覺察與經絡放鬆引導，陪你回到身體，釋放累積的緊繃與壓力。",
  },
];
---

<BaseLayout
  title="服務介紹"
  description="靜初苑服務介紹，包含服務內容、適合對象、費用與預約方式。"
>
  <section class="page">
    <div class="container split">
      <div>
        <p class="eyebrow">SERVICE</p>
        <h1>服務介紹</h1>
        <p class="lead">
          靜初苑提供問事、牌卡、香氣、蠟燭、家族排列與身體經絡放鬆引導，陪你從心、身體與空間慢慢回到穩定。
        </p>
        <div class="button-row">
          <a class="button" href="/contact/">詢問預約</a>
          <a class="button secondary" href="/faq/">閱讀 FAQ</a>
        </div>
      </div>
      <PictureSlot
        src="/images/service/service-scene.webp"
        alt="靜初苑服務情境"
        label="靜初苑服務"
        variant="tall"
      />
    </div>
  </section>

  <section class="band">
    <div class="container">
      <p class="eyebrow">DETAILS</p>
      <h2>服務內容</h2>
      <div class="grid service-grid">
        {
          services.map((service) => (
            <article class="card service-card">
              <div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
              </div>
              <div class="service-info">
                <span class="service-price">{service.price}</span>
                <span class="service-meta">{service.meta}</span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container split">
      <div>
        <p class="eyebrow">PRICE & BOOKING</p>
        <h2>費用與預約方式</h2>
        <p>
          若你還不確定自己適合哪一項服務，可以先透過 LINE 或 Instagram 簡單說明目前狀態，再一起確認合適的安排。
        </p>
        <ul class="list">
          <li>服務時間：依各服務標示時間或場次安排確認。</li>
          <li>進行方式：一對一、個案或團體場次可先私訊確認。</li>
          <li>預約流程：加入 LINE 或 Instagram 詢問，再一起確認時間。</li>
          <li>付款方式與注意事項：預約時一併說明。</li>
        </ul>
      </div>
      <div class="card highlight">
        <p class="eyebrow">NEXT STEP</p>
        <h3>先從一次簡單詢問開始</h3>
        <p>
          如果你不知道該怎麼描述自己的狀態，可以先留下一句目前最想被理解的事，再慢慢整理。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .highlight {
    background: #fff;
    align-self: stretch;
  }

  .service-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .service-card {
    display: grid;
    min-height: 238px;
    align-content: space-between;
    gap: 28px;
  }

  .service-card h3 {
    color: var(--color-gold-dark);
  }

  .service-card p {
    margin-bottom: 0;
  }

  .service-info {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    padding-top: 18px;
    border-top: 1px solid var(--color-line);
  }

  .service-price {
    color: var(--color-text);
    font-size: 24px;
    line-height: 1.2;
  }

  .service-meta {
    color: var(--color-muted);
    font-size: 14px;
    text-align: right;
  }

  @media (max-width: 640px) {
    .service-info {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }

    .service-meta {
      text-align: left;
    }
  }
</style>
