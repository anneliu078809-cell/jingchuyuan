---
import BaseLayout from "../layouts/BaseLayout.astro";
import PictureSlot from "../components/PictureSlot.astro";

const services = [
  {
    title: "問事服務",
    meta: "$2,600 / 1 到 1.5 小時",
    description: "透過一對一對話整理當前困惑，看見事件背後的狀態與下一步方向。",
  },
  {
    title: "牌卡占卜",
    meta: "$200 / 10 分鐘",
    description: "以牌卡作為提醒與映照，協助聚焦問題、釐清選擇與目前能量流向。",
  },
  {
    title: "手工藥香",
    meta: "$1,690 / 70g",
    description: "手工製作的藥香，適合用於日常靜心、空間安定與個人儀式感整理。",
  },
  {
    title: "調頻蠟燭",
    meta: "$1,200 / 200 到 220g",
    description: "結合香氣與燭光陪伴，為冥想、放鬆或空間轉換建立柔和穩定的氛圍。",
  },
  {
    title: "家族排列",
    meta: "個案 / 團體，費用與時間請私訊確認",
    description: "透過排列方式看見關係與系統中的牽動，讓卡住的議題有機會被重新理解。",
  },
  {
    title: "身體經絡放鬆引導",
    meta: "$2,000 / 1 小時",
    description: "以身體覺察與經絡放鬆引導，陪你回到身體，釋放累積的緊繃與壓力。",
  },
];
---

<BaseLayout
  title="服務介紹"
  description="靜初苑服務介紹，包含服務內容、適合對象、費用與預約方式。"
>
  <section class="page">
    <div class="container split">
      <div>
        <p class="eyebrow">SERVICE</p>
        <h1>服務介紹</h1>
        <p class="lead">
          靜初苑提供問事、牌卡、香氣、蠟燭、家族排列與身體經絡放鬆引導，陪你從心、身體與空間慢慢回到穩定。
        </p>
        <div class="button-row">
          <a class="button" href="/contact/">詢問預約</a>
          <a class="button secondary" href="/faq/">閱讀 FAQ</a>
        </div>
      </div>
      <PictureSlot
        src="/images/service/service-scene.webp"
        alt="靜初苑服務情境"
        label="靜初苑服務"
        variant="tall"
      />
    </div>
  </section>

  <section class="band">
    <div class="container">
      <p class="eyebrow">DETAILS</p>
      <h2>服務內容</h2>
      <div class="grid service-grid">
        {
          services.map((service) => (
            <article class="card service-card">
              <h3>{service.title}</h3>
              <p class="service-price-tag">{service.meta}</p>
              <p>{service.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container split">
      <div>
        <p class="eyebrow">PRICE & BOOKING</p>
        <h2>費用與預約方式</h2>
        <p>
          若你還不確定自己適合哪一項服務，可以先透過 LINE 或 Instagram 簡單說明目前狀態，再一起確認合適的安排。
        </p>
        <ul class="list">
          <li>服務時間：依各服務標示時間或場次安排確認。</li>
          <li>進行方式：一對一、個案或團體場次可先私訊確認。</li>
          <li>預約流程：加入 LINE 或 Instagram 詢問，再一起確認時間。</li>
          <li>付款方式與注意事項：預約時一併說明。</li>
        </ul>
      </div>
      <div class="card highlight">
        <p class="eyebrow">NEXT STEP</p>
        <h3>先從一次簡單詢問開始</h3>
        <p>
          如果你不知道該怎麼描述自己的狀態，可以先留下一句目前最想被理解的事，再慢慢整理。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .highlight {
    background: #fff;
    align-self: stretch;
  }

  .service-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .service-card {
    display: flex;
    min-height: 238px;
    flex-direction: column;
  }

  .service-card h3 {
    margin-bottom: 12px;
    color: var(--color-gold-dark);
  }

  .service-card p:last-child {
    margin-bottom: 0;
  }

  .service-price-tag {
    display: flex;
    align-items: center;
    width: fit-content;
    margin: 0 0 18px;
    padding: 10px 12px 10px 14px;
    border: 1px solid rgba(128, 85, 44, 0.34);
    background: rgba(255, 250, 244, 0.78);
    color: #654022;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.35;
  }

  @media (max-width: 900px) {
    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .service-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      min-height: 0;
    }
  }
</style>
