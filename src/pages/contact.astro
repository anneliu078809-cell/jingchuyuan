---
import BaseLayout from "../layouts/BaseLayout.astro";
import PictureSlot from "../components/PictureSlot.astro";

const lineAppUrl = "line://ti/p/%40eoo4230y";
const lineWebUrl = "https://line.me/R/ti/p/%40eoo4230y";
const contactEmail = "jingchuyuan1413@gmail.com";
const contactPhone = "0981328622";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout
  title="聯絡"
  description="聯絡靜初苑，可透過 LINE 或 Instagram 詢問服務與預約方式。"
  image="/images/contact/contact.webp"
>
  <section class="page">
    <div class="container split">
      <div>
        <p class="eyebrow">CONTACT</p>
        <h1>直接預約</h1>
        <p class="lead">
          目前可以Line官方帳號及Instagram 詢問服務與預約方式。
          謝謝你來到靜初苑。
          如果最近的生活有些迷惘、疲憊，或只是想找一個能安心說話的地方，我們都很歡迎你。
          願這裡，成為你偶爾停下腳步、重新整理心情的一處安靜角落。
          願每一次停下腳步，都是重新認識自己的開始。
        </p>
        <div class="button-row">
          <a
            class="button"
            href={lineWebUrl}
            aria-label="加入 LINE 官方帳號"
            target="_blank"
            rel="noreferrer"
            data-line-app-url={lineAppUrl}
            data-line-web-url={lineWebUrl}
          >
            加入 LINE
          </a>
          <a
            class="button secondary"
            href="https://www.instagram.com/jing_chu_yuan?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
            aria-label="前往 Instagram"
            target="_blank"
            rel="noreferrer"
          >
            Instagram
          </a>
        </div>
        <dl class="contact-details" aria-label="靜初苑聯絡資訊">
          <div>
            <dt>Email</dt>
            <dd><a href={`mailto:${contactEmail}`}>{contactEmail}</a></dd>
          </div>
          <!-- <div>
            <dt>電話</dt>
            <dd><a href={`tel:${contactPhone}`}>{contactPhone}</a></dd>
          </div> -->
        </dl>
      </div>
      <PictureSlot
        src="/images/contact/contact.webp"
        alt="靜初苑聯絡與預約意象"
        label="靜初苑聯絡"
      />
    </div>
  </section>

  <section class="band">
    <div class="container split">
      <div>
        <p class="eyebrow">FORM</p>
        <h2>聯絡表單</h2>
        <p>
          如果你想先留下資料，也可以填寫表單。收到後會再透過你留下的聯絡方式回覆。
        </p>
      </div>
      <form
        class="card contact-form"
        action="/api/contact"
        method="post"
        data-contact-form
        novalidate
      >
        <input
          type="text"
          name="_honey"
          autocomplete="off"
          tabindex="-1"
          aria-hidden="true"
          class="form-honey"
        />
        <p
          class="form-status"
          data-contact-status
          role="alert"
          aria-live="polite"
          hidden
        >
        </p>
        <label>
          姓名或暱稱
          <input
            type="text"
            name="姓名或暱稱"
            placeholder="請輸入姓名或暱稱"
            maxlength="10"
            required
            data-error-id="name-error"
          />
          <span class="field-error" id="name-error" data-field-error hidden
          ></span>
        </label>
        <label>
          想詢問的服務
          <select name="想詢問的服務" required data-error-id="service-error">
            <option value="">請選擇</option>
            <option>問事服務</option>
            <option>牌卡占卜</option>
            <option>手工藥香</option>
            <option>調頻蠟燭</option>
            <option>家族排列</option>
            <option>身體經絡放鬆引導</option>
            <option>還不確定，想先詢問</option>
          </select>
          <span class="field-error" id="service-error" data-field-error hidden
          ></span>
        </label>
        <label>
          偏好的聯絡方式
          <select
            name="偏好的聯絡方式"
            required
            data-error-id="contact-method-error"
          >
            <option value="">請選擇</option>
            <option>LINE ID</option>
            <option>電話</option>
            <option>Email</option>
            <option>Instagram</option>
          </select>
          <span
            class="field-error"
            id="contact-method-error"
            data-field-error
            hidden></span>
        </label>
        <label>
          聯絡資料
          <input
            type="text"
            name="聯絡資料"
            placeholder="請填寫帳號、電話或 Email"
            maxlength="160"
            required
            data-error-id="contact-value-error"
          />
          <span
            class="field-error"
            id="contact-value-error"
            data-field-error
            hidden></span>
        </label>
        <label>
          想聊的方向
          <textarea
            name="想聊的方向"
            placeholder="可簡單說明目前需求，最多300個字"
            maxlength="300"
            data-error-id="message-error"></textarea>
          <span class="field-error" id="message-error" data-field-error hidden
          ></span>
        </label>
        {
          turnstileSiteKey && (
            <div class="turnstile-wrap">
              <div class="cf-turnstile" data-sitekey={turnstileSiteKey} />
            </div>
          )
        }
        <button class="button" type="submit">送出表單</button>
      </form>
    </div>
  </section>
</BaseLayout>

{
  turnstileSiteKey && (
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    />
  )
}

<script>
  const contactForm = document.querySelector<HTMLFormElement>(
    "[data-contact-form]",
  );
  const statusMessage = document.querySelector<HTMLElement>(
    "[data-contact-status]",
  );
  const contactSubmitButton = contactForm?.querySelector<HTMLButtonElement>(
    'button[type="submit"]',
  );
  const requiredFieldMessages = new Map<string, string>([
    ["姓名或暱稱", "請填寫姓名或暱稱"],
    ["想詢問的服務", "請選擇想詢問的服務"],
    ["偏好的聯絡方式", "請選擇偏好的聯絡方式"],
    ["聯絡資料", "請填寫聯絡資料"],
  ]);
  const fieldMaxLengths = new Map<string, { max: number; message: string }>([
    ["姓名或暱稱", { max: 10, message: "姓名或暱稱最多 10 個字" }],
    ["聯絡資料", { max: 160, message: "聯絡資料最多 160 個字" }],
    ["想聊的方向", { max: 300, message: "想聊的方向最多 300 個字" }],
  ]);

  const showFormStatus = (message: string, type: "success" | "error") => {
    if (!statusMessage) {
      return;
    }

    statusMessage.hidden = false;
    statusMessage.textContent = message;
    statusMessage.dataset.type = type;
    statusMessage.scrollIntoView({ block: "nearest", behavior: "smooth" });
  };

  const resetTurnstile = () => {
    const turnstile = (
      window as Window & { turnstile?: { reset?: () => void } }
    ).turnstile;
    turnstile?.reset?.();
  };

  const getContactAction = () => {
    const localHosts = new Set(["localhost", "127.0.0.1"]);

    if (localHosts.has(window.location.hostname)) {
      return "http://127.0.0.1:4322/api/contact";
    }

    return contactForm?.action || "/api/contact";
  };

  const clearFieldErrors = () => {
    contactForm
      ?.querySelectorAll<
        HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
      >("[aria-invalid='true']")
      .forEach((field) => {
        field.removeAttribute("aria-invalid");
        field.removeAttribute("aria-describedby");
      });

    contactForm
      ?.querySelectorAll<HTMLElement>("[data-field-error]")
      .forEach((error) => {
        error.hidden = true;
        error.textContent = "";
      });
  };

  const hideFormStatus = () => {
    if (!statusMessage) {
      return;
    }

    statusMessage.hidden = true;
    statusMessage.textContent = "";
    delete statusMessage.dataset.type;
  };

  const showFieldError = (
    field: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement,
    message: string,
  ) => {
    const errorId = field.dataset.errorId;

    field.setAttribute("aria-invalid", "true");

    if (!errorId) {
      return;
    }

    const error = document.getElementById(errorId);

    if (!error) {
      return;
    }

    error.textContent = message;
    error.hidden = false;
    field.setAttribute("aria-describedby", errorId);
  };

  const bindFieldErrorReset = () => {
    contactForm
      ?.querySelectorAll<
        HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
      >("[data-error-id]")
      .forEach((field) => {
        const clearCurrentFieldError = () => {
          if (!field.value.trim()) {
            return;
          }

          field.removeAttribute("aria-invalid");
          field.removeAttribute("aria-describedby");

          const errorId = field.dataset.errorId;
          const error = errorId ? document.getElementById(errorId) : null;

          if (error) {
            error.hidden = true;
            error.textContent = "";
          }
        };

        if (field instanceof HTMLSelectElement) {
          field.addEventListener("change", clearCurrentFieldError);
          return;
        }

        const limitTextInput = () => {
          const maxLength = Number(field.getAttribute("maxlength"));

          if (
            Number.isFinite(maxLength) &&
            maxLength > -1 &&
            field.value.length > maxLength
          ) {
            field.value = field.value.slice(0, maxLength);
          }

          clearCurrentFieldError();
        };

        field.addEventListener("input", limitTextInput);
        field.addEventListener("change", limitTextInput);
      });
  };

  const getValidationMessages = () => {
    if (!contactForm) {
      return [];
    }

    clearFieldErrors();

    const invalidFields: Array<
      HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
    > = [];
    const messages: string[] = [];

    Array.from(requiredFieldMessages.entries()).forEach(
      ([fieldName, message]) => {
        const field = contactForm.elements.namedItem(fieldName) as
          | HTMLInputElement
          | HTMLSelectElement
          | null;

        if (!field || field.value.trim()) {
          return;
        }

        showFieldError(field, message);
        invalidFields.push(field);
        messages.push(message);
      },
    );

    Array.from(fieldMaxLengths.entries()).forEach(
      ([fieldName, { max, message }]) => {
        const field = contactForm.elements.namedItem(fieldName) as
          | HTMLInputElement
          | HTMLTextAreaElement
          | null;

        if (!field || field.value.length <= max) {
          return;
        }

        field.value = field.value.slice(0, max);
        showFieldError(field, message);
        invalidFields.push(field);
        messages.push(message);
      },
    );

    invalidFields[0]?.focus();
    return messages;
  };

  contactForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!contactSubmitButton) {
      return;
    }

    const validationMessages = getValidationMessages();

    if (validationMessages.length) {
      hideFormStatus();
      return;
    }

    contactSubmitButton.disabled = true;

    try {
      const response = await fetch(getContactAction(), {
        method: contactForm.method,
        body: new FormData(contactForm),
        headers: {
          Accept: "application/json",
        },
      });
      const result = (await response.json().catch(() => null)) as {
        ok?: boolean;
        message?: string;
      } | null;

      if (!response.ok || !result?.ok) {
        const message =
          result?.message ||
          "表單暫時無法送出，請稍後再試，或直接透過 LINE 聯絡。";
        showFormStatus(message, "error");
        resetTurnstile();
        return;
      }

      const message = result.message || "發送成功";
      contactForm.reset();
      clearFieldErrors();
      showFormStatus(message, "success");
      resetTurnstile();
    } catch {
      const message = "表單暫時無法送出，請稍後再試，或直接透過 LINE 聯絡。";
      showFormStatus(message, "error");
      resetTurnstile();
    } finally {
      contactSubmitButton.disabled = false;
    }
  });

  bindFieldErrorReset();

  const isMobileDevice = () =>
    window.matchMedia("(pointer: coarse)").matches ||
    /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent);

  document
    .querySelectorAll<HTMLAnchorElement>(
      "[data-line-app-url][data-line-web-url]",
    )
    .forEach((link) => {
      link.addEventListener("click", (event) => {
        const appUrl = link.dataset.lineAppUrl;
        const webUrl = link.dataset.lineWebUrl;

        if (!appUrl || !webUrl) {
          return;
        }

        if (!isMobileDevice()) {
          return;
        }

        event.preventDefault();
        window.location.href = appUrl;
        window.setTimeout(() => {
          if (!document.hidden) {
            window.location.href = webUrl;
          }
        }, 900);
      });
    });
</script>

<style>
  .contact-details {
    display: grid;
    gap: 10px;
    margin: 28px 0 0;
    padding: 18px 20px;
    border-left: 2px solid var(--color-gold);
    background: rgba(255, 250, 244, 0.72);
  }

  .contact-details div {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 14px;
    align-items: baseline;
  }

  .contact-details dt {
    color: var(--color-gold-dark);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-details dd {
    margin: 0;
    color: var(--color-text);
    font-size: 16px;
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .contact-details a {
    color: inherit;
    text-decoration-color: rgba(128, 85, 44, 0.35);
    text-underline-offset: 4px;
  }

  .contact-details a:hover {
    color: var(--color-gold-dark);
  }

  .contact-form {
    align-self: start;
  }

  .contact-form .button {
    width: fit-content;
    margin-top: 4px;
    cursor: pointer;
  }

  .contact-form .button:disabled {
    cursor: wait;
    opacity: 0.62;
  }

  .form-honey {
    position: absolute;
    left: -9999px;
  }

  .form-status {
    margin: 0;
    padding: 12px 14px;
    border: 1px solid rgba(189, 146, 82, 0.32);
    background: rgba(247, 241, 231, 0.72);
    color: var(--color-text);
    font-size: 15px;
    white-space: pre-line;
  }

  .form-status[data-type="error"] {
    border-color: rgba(150, 67, 54, 0.35);
    color: #8f352b;
  }

  .field-error {
    margin-top: -10px;
    color: #8f352b;
    font-size: 14px;
    line-height: 1.45;
  }

  .contact-form :is(input, select, textarea)[aria-invalid="true"] {
    border-color: rgba(150, 67, 54, 0.72);
    box-shadow: 0 0 0 3px rgba(150, 67, 54, 0.1);
  }

  .turnstile-wrap {
    min-height: 65px;
  }

  @media (max-width: 640px) {
    .contact-details div {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .contact-form .button {
      width: 100%;
    }
  }
</style>
