---
import BaseLayout from "../layouts/BaseLayout.astro";
import PictureSlot from "../components/PictureSlot.astro";

const lineAppUrl = "line://ti/p/%40eoo4230y";
const lineWebUrl = "https://line.me/R/ti/p/%40eoo4230y";
const contactEmail = "jingchuyuan1413@gmail.com";
const contactPhone = "0981328622";
---

<BaseLayout
  title="聯絡"
  description="聯絡靜初苑，可透過 LINE 或 Instagram 詢問服務與預約方式。"
>
  <section class="page">
    <div class="container split">
      <div>
        <p class="eyebrow">CONTACT</p>
        <h1>聯絡與預約</h1>
        <p class="lead">
          目前建議先以 LINE 官方帳號作為主要聯絡管道，也可以透過 Instagram 詢問服務與預約方式。
        </p>
        <div class="button-row">
          <a
            class="button"
            href={lineWebUrl}
            aria-label="加入 LINE 官方帳號"
            target="_blank"
            rel="noreferrer"
            data-line-app-url={lineAppUrl}
            data-line-web-url={lineWebUrl}
          >
            加入 LINE
          </a>
          <a
            class="button secondary"
            href="https://www.instagram.com/jing_chu_yuan?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
            aria-label="前往 Instagram"
            target="_blank"
            rel="noreferrer"
          >
            Instagram
          </a>
        </div>
        <dl class="contact-details" aria-label="靜初苑聯絡資訊">
          <div>
            <dt>Email</dt>
            <dd><a href={`mailto:${contactEmail}`}>{contactEmail}</a></dd>
          </div>
          <div>
            <dt>電話</dt>
            <dd><a href={`tel:${contactPhone}`}>{contactPhone}</a></dd>
          </div>
        </dl>
      </div>
      <PictureSlot
        src="/images/contact/contact.webp"
        alt="靜初苑聯絡與預約意象"
        label="靜初苑聯絡"
      />
    </div>
  </section>

  <section class="band">
    <div class="container split">
      <div>
        <p class="eyebrow">FORM</p>
        <h2>聯絡表單</h2>
        <p>
          如果你想先留下資料，也可以填寫表單。收到後會再透過你留下的聯絡方式回覆。
        </p>
      </div>
      <form class="card contact-form" action="/api/contact" method="post">
        <input type="text" name="_honey" autocomplete="off" tabindex="-1" aria-hidden="true" class="form-honey" />
        <p class="form-status" data-contact-status hidden></p>
        <label>
          姓名或暱稱
          <input type="text" name="姓名或暱稱" placeholder="請輸入姓名或暱稱" required />
        </label>
        <label>
          想詢問的服務
          <select name="想詢問的服務" required>
            <option value="">請選擇</option>
            <option>問事服務</option>
            <option>牌卡占卜</option>
            <option>手工藥香</option>
            <option>調頻蠟燭</option>
            <option>家族排列</option>
            <option>身體經絡放鬆引導</option>
            <option>還不確定，想先詢問</option>
          </select>
        </label>
        <label>
          偏好的聯絡方式
          <select name="偏好的聯絡方式" required>
            <option value="">請選擇</option>
            <option>LINE ID</option>
            <option>電話</option>
            <option>Email</option>
            <option>Instagram</option>
          </select>
        </label>
        <label>
          聯絡資料
          <input type="text" name="聯絡資料" placeholder="請填寫帳號、電話或 Email" required />
        </label>
        <label>
          想聊的方向
          <textarea name="想聊的方向" placeholder="可簡單說明目前需求，選填即可"></textarea>
        </label>
        <button class="button" type="submit">送出表單</button>
      </form>
    </div>
  </section>

</BaseLayout>

<script>
  const statusMessage = document.querySelector<HTMLElement>("[data-contact-status]");
  const urlParams = new URLSearchParams(window.location.search);

  if (statusMessage && urlParams.get("sent") === "1") {
    statusMessage.hidden = false;
    statusMessage.textContent = "表單已送出，收到後會再透過你留下的方式回覆。";
    statusMessage.dataset.type = "success";
  }

  if (statusMessage && urlParams.get("error") === "1") {
    statusMessage.hidden = false;
    statusMessage.textContent = "表單暫時無法送出，請稍後再試，或直接透過 LINE 聯絡。";
    statusMessage.dataset.type = "error";
  }

  const isMobileDevice = () =>
    window.matchMedia("(pointer: coarse)").matches ||
    /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent);

  document.querySelectorAll<HTMLAnchorElement>("[data-line-app-url][data-line-web-url]").forEach((link) => {
    link.addEventListener("click", (event) => {
      const appUrl = link.dataset.lineAppUrl;
      const webUrl = link.dataset.lineWebUrl;

      if (!appUrl || !webUrl) {
        return;
      }

      if (!isMobileDevice()) {
        return;
      }

      event.preventDefault();
      window.location.href = appUrl;
      window.setTimeout(() => {
        if (!document.hidden) {
          window.location.href = webUrl;
        }
      }, 900);
    });
  });
</script>

<style>
  .contact-details {
    display: grid;
    gap: 10px;
    margin: 28px 0 0;
    padding: 18px 20px;
    border-left: 2px solid var(--color-gold);
    background: rgba(255, 250, 244, 0.72);
  }

  .contact-details div {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 14px;
    align-items: baseline;
  }

  .contact-details dt {
    color: var(--color-gold-dark);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-details dd {
    margin: 0;
    color: var(--color-text);
    font-size: 16px;
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .contact-details a {
    color: inherit;
    text-decoration-color: rgba(128, 85, 44, 0.35);
    text-underline-offset: 4px;
  }

  .contact-details a:hover {
    color: var(--color-gold-dark);
  }

  .contact-form {
    align-self: start;
  }

  .contact-form .button {
    width: fit-content;
    margin-top: 4px;
    cursor: pointer;
  }

  .form-honey {
    position: absolute;
    left: -9999px;
  }

  .form-status {
    margin: 0;
    padding: 12px 14px;
    border: 1px solid rgba(189, 146, 82, 0.32);
    background: rgba(247, 241, 231, 0.72);
    color: var(--color-text);
    font-size: 15px;
  }

  .form-status[data-type="error"] {
    border-color: rgba(150, 67, 54, 0.35);
    color: #8f352b;
  }

  @media (max-width: 640px) {
    .contact-details div {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .contact-form .button {
      width: 100%;
    }
  }
</style>
